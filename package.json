{
  "name": "@rundown-studio/utils",
  "version": "0.12.0",
  "description": "Shared helper functions for the Rundown Studio project",
  "license": "ISC",
  "author": "Lukas Hermann <hey@lukashermann.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rundown-studio/package-utils.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest --run --no-color",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@types/lodash": "^4.17.7",
    "@types/node": "^25.9.1",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "jiti": "^2.7.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@rundown-studio/consts": "0.7.1",
    "@rundown-studio/timeutils": "0.7.1",
    "@rundown-studio/types": "1.10.3",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21"
  }
}

{
  "name": "@rundown-studio/utils",
  "version": "1.2.0",
  "description": "Shared helper functions for the Rundown Studio project",
  "license": "ISC",
  "author": "Lukas Hermann <hey@lukashermann.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rundown-studio/package-utils.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest --run --no-color",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rundown-studio/types": "^1.13.2",
    "@types/html-to-text": "9.0.4",
    "@types/lodash": "^4.17.7",
    "@types/node": "^25.9.1",
    "@types/sanitize-html": "2.16.1",
    "fast-deep-equal": "^3.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@rundown-studio/consts": "0.7.1",
    "@rundown-studio/timeutils": "1.0.0",
    "date-fns": "^4.1.0",
    "html-to-text": "9.0.5",
    "lodash": "^4.17.21",
    "sanitize-html": "2.17.4"
  },
  "peerDependencies": {
    "@rundown-studio/types": "^1.13.2"
  }
}
